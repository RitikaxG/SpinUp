# ----------------------------
# Local compose runtime
# ----------------------------
NODE_ENV=development
NEXT_TELEMETRY_DISABLED=1

# These URLs are for services running INSIDE docker compose
DATABASE_URL=postgresql://postgres:postgres@postgres:5432/spinup_local
REDIS_URL=redis://redis:6379

# ----------------------------
# SpinUp control plane config
# ----------------------------
PROJECT_ARTIFACT_BUCKET=bolt-app-v1
AWS_REGION=ap-south-1
ASG_NAME=codeserver-autoscaling-group

# Local compose containers are NOT on EC2, so use explicit AWS creds here.
# Do not use these for the EC2 workspace runtime path.
AWS_AUTH_MODE=explicit
EC2_LAUNCHER_ACCESS_KEY=your_local_aws_access_key
EC2_LAUNCHER_ACCESS_SECRET=your_local_aws_secret_key

# Optional preflight target
PREFLIGHT_VM_AGENT_BASE_URL=

# VM / workspace config
VM_AGENT_PORT=3000
VM_AGENT_HEALTH_TIMEOUT_MS=30000
VM_AGENT_POLL_INTERVAL_MS=2000
VM_AGENT_REQUEST_TIMEOUT_MS=15000
VM_CONTAINER_RUNNING_TIMEOUT_MS=60000
WORKSPACE_PORT=8080
WORKSPACE_READY_TIMEOUT_MS=300000
WORKSPACE_READY_POLL_INTERVAL_MS=5000

# Debug / failure behavior
PRESERVE_FAILED_RUNTIME_FOR_DEBUG=false
FAILED_RUNTIME_DEBUG_GRACE_MS=0

# ----------------------------
# Clerk
# Fill with your real local values
# ----------------------------
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=your_clerk_publishable_key
CLERK_SECRET_KEY=your_clerk_secret_key